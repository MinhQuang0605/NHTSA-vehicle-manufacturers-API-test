{
  "info": {
    "_postman_id": "8727e318-10e1-4b8f-a1c5-49855843d628",
    "name": "NHTSA vehicle manufacturers API test",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "49381996",
    "_collection_link": "https://go.postman.co/collection/49381996-8727e318-10e1-4b8f-a1c5-49855843d628?source=collection_link"
  },
  "item": [
    {
      "name": "Car Manufacture",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"1. Response time is acceptable: <2000ms\", function () {\r",
              "    pm.expect(pm.response.responseTime).to.be.below(2000);\r",
              "    console.log(\"response time:\", pm.response.responseTime);\r",
              "})\r",
              "\r",
              "//Test case định dạng response\r",
              "pm.test(\"2. Response is in Valid JSON format\", function () {\r",
              "    //pm.expect(pm.response.headers.get(\"Content-Type\")).to.include(\"application/json\");\r",
              "    pm.response.to.be.json;\r",
              "})\r",
              "\r",
              "pm.test(\"3. Content-Type is JSON\", function () {\r",
              "    pm.expect(pm.response.headers.get(\"Content-Type\")).to.include(\"application/json\");\r",
              "});\r",
              "// pm.test(\"Response has required fields\", function () {\r",
              "//     const jsonData = pm.response.json();\r",
              "//     pm.expect(jsonData).to.have.property(\"Mfr_ID\");\r",
              "//     pm.expect(jsonData).to.have.property(\"Mfr_Name\");\r",
              "// });\r",
              "\r",
              "let jsonData = pm.response.json();\r",
              "\r",
              "pm.test(\"4. Response Status 200\", () => {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"5. Results exists and not empty\", () => {\r",
              "    pm.expect(jsonData.Results).to.be.an(\"array\").that.is.not.empty;\r",
              "});\r",
              "\r",
              "pm.test(\"6. Validate first manufacturer\", () => {\r",
              "    let item = jsonData.Results[0];\r",
              "\r",
              "    pm.expect(item.Mfr_ID).to.be.a(\"number\");\r",
              "    pm.expect(item.Mfr_Name).to.be.a(\"string\");\r",
              "    pm.expect(item.VehicleTypes).to.be.an(\"array\");\r",
              "});\r",
              "\r",
              "pm.test(\"7. VehicleTypes structure is correct\", function () {\r",
              "    let vehicleType = pm.response.json().Results[0].VehicleTypes[0];\r",
              "\r",
              "    pm.expect(vehicleType).to.have.property(\"IsPrimary\");\r",
              "    pm.expect(vehicleType).to.have.property(\"Name\");\r",
              "\r",
              "    pm.expect(vehicleType.IsPrimary).to.be.a(\"boolean\");\r",
              "    pm.expect(vehicleType.Name).to.be.a(\"string\");\r",
              "});\r",
              "\r",
              "pm.test(\"8. Count matches Results length\", () => {\r",
              "    pm.expect(jsonData.Count).to.be.at.least(jsonData.Results.length);\r",
              "});\r",
              "//structure cua reponse body\r",
              "const schema = {\r",
              "    type: \"object\",\r",
              "    required: [\"Count\", \"Results\"],\r",
              "    properties: {\r",
              "        Count: { type: \"number\" },\r",
              "        Results: {\r",
              "            type: \"array\",\r",
              "            items: {\r",
              "                type: \"object\",\r",
              "                required: [\"Mfr_ID\", \"Mfr_Name\", \"Country\", \"VehicleTypes\"]\r",
              "            }\r",
              "        }\r",
              "    }\r",
              "};\r",
              "\r",
              "pm.test(\"9. Schema is valid\", () => {\r",
              "    pm.response.to.have.jsonSchema(schema);\r",
              "});\r",
              "\r",
              "pm.test(\"10. Validate all manufacturers\", () => {\r",
              "    jsonData.Results.forEach(item => {\r",
              "        pm.expect(item.Mfr_ID).to.be.a(\"number\");\r",
              "        pm.expect(item.Mfr_Name).to.be.a(\"string\");\r",
              "        pm.expect(item.VehicleTypes).to.be.an(\"array\");\r",
              "    });\r",
              "});\r",
              "\r",
              "pm.test(\"11. Validate vehicle types structure\", () => {\r",
              "    jsonData.Results.forEach(item => {\r",
              "        item.VehicleTypes.forEach(vehicle => {\r",
              "            pm.expect(vehicle.IsPrimary).to.be.a(\"boolean\");\r",
              "            pm.expect(vehicle.Name).to.be.a(\"string\");\r",
              "        });\r",
              "    });\r",
              "});\r",
              "\r",
              "pm.test(\"12. Mfr_ID is not null\", () => {\r",
              "    let item = pm.response.json().Results[0];\r",
              "    pm.expect(item.Mfr_ID).to.not.be.null;\r",
              "});\r",
              "\r",
              "pm.test(\"13. IsPrimary is boolean\", () => {\r",
              "    let vehicle = pm.response.json().Results[0].VehicleTypes[0];\r",
              "    pm.expect(vehicle.IsPrimary).to.be.a(\"boolean\");\r",
              "});\r",
              "\r",
              "pm.test(\"14. Manufacturer name should not be empty\", () => {\r",
              "    jsonData.Results.forEach(item => {\r",
              "        pm.expect(item.Mfr_Name).to.not.be.empty;\r",
              "    });\r",
              "});\r",
              "\r",
              "pm.test(\"15. Each manufacturer must have at least one vehicle type\", () => {\r",
              "    jsonData.Results.forEach(item => {\r",
              "        console.log(\"-------------------------------------\")\r",
              "        console.log(\"Mfr_ID:\", item.Mfr_ID)\r",
              "        console.log(\"Result: \",item.VehicleTypes.length)\r",
              "        pm.expect(item.VehicleTypes.length).to.be.above(0);\r",
              "    });\r",
              "});\r",
              "\r",
              "pm.test(\"16. Mfr_ID should be unique\", () => {\r",
              "    let results = pm.response.json().Results;\r",
              "    let ids = results.map(r => r.Mfr_ID);\r",
              "    let uniqueIds = [...new Set(ids)];\r",
              "    pm.expect(ids.length).to.eql(uniqueIds.length);\r",
              "});\r",
              "\r",
              "// pm.test(\"17. Results should be empty when not found\", () => {\r",
              "//     let jsonData = pm.response.json();\r",
              "//     pm.expect(jsonData.Results).to.be.an(\"array\");\r",
              "// });\r",
              "\r",
              "\r",
              "\r",
              "pm.test(\"17. Validate manufacturer all data structure\", () => {\r",
              "    jsonData.Results.forEach(item => {\r",
              "\r",
              "        pm.expect(item.Mfr_ID).to.be.a(\"number\");\r",
              "        pm.expect(item.Mfr_Name).to.be.a(\"string\");\r",
              "        pm.expect(item.VehicleTypes).to.be.an(\"array\");\r",
              "\r",
              "        item.VehicleTypes.forEach(vehicle => {\r",
              "            pm.expect(vehicle.IsPrimary).to.be.a(\"boolean\");\r",
              "            pm.expect(vehicle.Name).to.be.a(\"string\");\r",
              "        });\r",
              "\r",
              "    });\r",
              "});\r",
              "\r",
              "pm.test(\"18. Each manufacturer has only one primary vehicle type\", function () {\r",
              "    \r",
              "    jsonData.Results.forEach(company => {\r",
              "\r",
              "        if (!company.VehicleTypes || company.VehicleTypes.length === 0) {\r",
              "            return; // bo que vehicle type rong\r",
              "        }\r",
              "\r",
              "        const primaryCount = company.VehicleTypes.filter(v => v.IsPrimary === true).length;\r",
              "\r",
              "        pm.expect(primaryCount, `Manufacturer ${company.Mfr_Name} has more than one primary vehicle type`)\r",
              "            .to.be.at.most(1);\r",
              "\r",
              "    });\r",
              "\r",
              "});\r",
              "\r",
              "pm.test(\" Random Id test\", () => {\r",
              "    let randomIndex = Math.floor(Math.random() * jsonData.Results.length);\r",
              "    let item = jsonData.Results[randomIndex];\r",
              "    console.log(\"Random Mfr_ID: \", randomIndex);\r",
              "    pm.expect(item.Mfr_ID).to.be.a(\"number\");\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "https://vpic.nhtsa.dot.gov/api/vehicles/getallmanufacturers?format=json",
          "protocol": "https",
          "host": [
            "vpic",
            "nhtsa",
            "dot",
            "gov"
          ],
          "path": [
            "api",
            "vehicles",
            "getallmanufacturers"
          ],
          "query": [
            {
              "key": "format",
              "value": "json"
            }
          ]
        }
      },
      "response": []
    }
  ]
}